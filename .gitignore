# Rust build artifacts
/target/

# Backtraces
*.bt

# Editor / OS cruft
.DS_Store
*.swp
.idea/
# Keep .vscode/ out by default; add specific shared files if needed later
.vscode/

# Engine-specific large/generated assets (added as the project grows)
# Training data, nets, books, tablebases — keep these out of git history.
*.nnue
*.bin
*.pgn
*.epd
# …but the curated SPRT opening book is committed (issue #31); allowlist it.
# This negation must stay after `*.epd` — later patterns win.
!/books/openings.epd
# Ignore the data dir's contents (datasets are large), but keep a small committed
# Texel sample (issue #42) so the tuner can be smoke-run without a multi-GB set.
# `/data/*` (not `/data/`) is required: git won't descend into a fully-excluded
# directory, so a file negation can only re-include when the dir itself isn't excluded.
/data/*
!/data/texel_sample.txt
/nets/

# Match-runner (fastchess/cutechess) artifacts written into the working dir.
/config.json
# SPRT runner (scripts/sprt.sh) tee'd log + PGN (PGN also matches *.pgn above).
/sprt.log
/sprt.pgn
# Gauntlet runner (scripts/gauntlet.sh) artifacts (PGN also matches *.pgn above).
/gauntlet.log
/gauntlet.pgn
/gauntlet-ratings.txt
# Stashed baseline engine binary (the tagged-release SPRT opponent).
/baseline/
